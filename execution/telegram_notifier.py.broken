    def notify_error(self, error: Dict) -> bool:
        """
        Notify error
        
        Args:
            error: Error details
            
        Returns:
            bool: Success status
        """
        message = f"""⚠️ *ERROR ALERT!* {self.mode_prefix}

━━━━━━━━━━━━━━━━━━━━━━━━
