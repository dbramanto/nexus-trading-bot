━━━━━━━━━━━━━━━━━━━━━━━━

*Score:* {trade['score']:.1f}/100 ({trade['grade']})
*Setup:* {trade.get('setup_type', 'N/A')}
*Reason:* {trade.get('reason', 'N/A')}

━━━━━━━━━━━━━━━━━━━━━━━━
