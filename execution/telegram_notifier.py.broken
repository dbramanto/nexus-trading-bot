"""
NEXUS Bot - Telegram Notifier
Sends trading notifications via Telegram
"""

import logging
import os
from typing import Dict, List, Optional
from datetime import datetime
import asyncio
from telegram import Bot
from telegram.error import TelegramError

# Setup logging
logger = logging.getLogger(__name__)


class TelegramNotifier:
    """
    Telegram notification system for NEXUS bot
    
    Features:
    - Trade alerts (open/close/TP/SL)
    - Daily reports
    - Daily loss warnings
    - Account summaries
    - Error notifications
    - File uploads (reports)
    """
    
    def __init__(
        self,
        bot_token: str,
        chat_id: str,
        enabled: bool = True,
        mode_prefix: str = "[PAPER]"
    ):
        """
        Initialize Telegram notifier
        
        Args:
            bot_token: Telegram bot token
            chat_id: Telegram chat ID
            enabled: Enable/disable notifications
            mode_prefix: Prefix for messages (e.g., [PAPER] or [LIVE])
        """
        self.bot_token = bot_token
        self.chat_id = chat_id
        self.enabled = enabled
        self.mode_prefix = mode_prefix
        
        # Initialize bot
        if self.enabled and self.bot_token and self.chat_id:
            self.bot = Bot(token=self.bot_token)
            logger.info(f"TelegramNotifier initialized (enabled, mode={mode_prefix})")
        else:
            self.bot = None
            logger.warning("TelegramNotifier disabled (missing token or chat ID)")
    
    async def _send_message(self, message: str) -> bool:
        """
        Send message to Telegram
        
        Args:
            message: Message text
            
        Returns:
            bool: Success status
        """
        if not self.enabled or not self.bot:
            logger.debug("Telegram notifications disabled - skipping")
            return False
        
        try:
            await self.bot.send_message(
                chat_id=self.chat_id,
                text=message,
                parse_mode='Markdown'
            )
            logger.debug("Telegram message sent successfully")
            return True
            
        except TelegramError as e:
            logger.error(f"Telegram error: {e}")
            return False
        except Exception as e:
            logger.error(f"Failed to send Telegram message: {e}")
            return False
    
    def send_message(self, message: str):
        """Send message to Telegram (event-loop safe)"""
        import asyncio
        try:
            # Create new event loop if needed
            try:
                loop = asyncio.get_event_loop()
                if loop.is_closed():
                    loop = asyncio.new_event_loop()
                    asyncio.set_event_loop(loop)
            except RuntimeError:
                loop = asyncio.new_event_loop()
                asyncio.set_event_loop(loop)
            
            # Send message
            self.bot.send_message(
                chat_id=self.chat_id,
                text=message,
                parse_mode='Markdown'
            )
        except Exception as e:
            logger.error(f"Telegram error: {e}")
    
    # ═══════════════════════════════════════════════════════
    # NOTIFICATION TEMPLATES
    # ═══════════════════════════════════════════════════════
    
    def notify_bot_started(self, config: Dict) -> bool:
        """
        Notify bot started
        
        Args:
            config: Bot configuration
            
        Returns:
            bool: Success status
        """
        message = f"""🤖 *NEXUS BOT STARTED* {self.mode_prefix}
━━━━━━━━━━━━━━━━━━━━━━━━

*Mode:* {config.get('mode', 'Paper Trading')}
*Balance:* ${config.get('balance', 0):,.2f}
*Symbols:* {', '.join(config.get('symbols', []))}

*Risk Management:*
- Risk/Trade: {config.get('risk_per_trade', 1)}%
- Max Position: {config.get('max_position', 25)}%
- Leverage: {config.get('min_leverage', 10)}-{config.get('max_leverage', 20)}x
- Daily Limit: -{config.get('daily_limit', 5)}%

⏰ Started: {config.get('start_time', 'N/A')}

✅ Bot monitoring market..."""

        return self.send_message(message)
    
