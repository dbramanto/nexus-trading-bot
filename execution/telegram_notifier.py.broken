━━━━━━━━━━━━━━━━━━━━━━━━

*Type:* {error.get('type', 'Unknown')}
*Component:* {error.get('component', 'Unknown')}
*Message:* {error.get('message', 'N/A')}

*Impact:* {error.get('impact', 'Unknown')}
*Action:* {error.get('action', 'Automatic retry')}

⏰ {error.get('timestamp', 'N/A')}

System will notify when resolved."""

        return self.send_message(message)


# Convenience function
# Convenience function
def get_telegram_notifier(
    bot_token: Optional[str] = None,
    chat_id: Optional[str] = None,
    enabled: bool = True,
    mode_prefix: str = "[PAPER]"
) -> TelegramNotifier:
    """
    Factory function to create TelegramNotifier
    
    Args:
        bot_token: Bot token (or from env)
        chat_id: Chat ID (or from env)
        enabled: Enable notifications
        mode_prefix: Mode prefix
        
    Returns:
        TelegramNotifier instance
    """
    # Get from env if not provided
    if not bot_token:
        bot_token = os.getenv('TELEGRAM_BOT_TOKEN')
    if not chat_id:
        chat_id = os.getenv('TELEGRAM_CHAT_ID')
    
    # Check enabled flag
    enabled_str = os.getenv('TELEGRAM_ENABLED', 'true').lower()
    if enabled_str in ['false', '0', 'no']:
        enabled = False
    
    return TelegramNotifier(bot_token, chat_id, enabled, mode_prefix)


